#!/usr/bin/env bash
set -Eeuo pipefail

BACKUP_DIR="{{ ipa_backup_dir }}"
LOG_DIR="{{ ipa_backup_log_dir }}"
MANIFEST_DIR="{{ ipa_backup_manifest_dir }}"
RETENTION_DAYS="{{ ipa_backup_retention_days }}"
LOG_FILE="${LOG_DIR}/ipa-backup-$(date +%F).log"

mkdir -p "${BACKUP_DIR}" "${LOG_DIR}" "${MANIFEST_DIR}"
chmod 0750 "${BACKUP_DIR}" "${LOG_DIR}" "${MANIFEST_DIR}"
exec >> "${LOG_FILE}" 2>&1

echo "[$(date --iso-8601=seconds)] Starting IRIVEN IPA backup"

command -v ipa-backup >/dev/null 2>&1 || { echo "ipa-backup not found"; exit 1; }
ipactl status >/dev/null 2>&1 || { echo "FreeIPA services are not healthy"; ipactl status || true; exit 1; }

before_list="$(mktemp)"
after_list="$(mktemp)"
find "${BACKUP_DIR}" -mindepth 1 -maxdepth 1 -type d -name 'ipa-full-*' -print | sort > "${before_list}"

BACKUP_ARGS=(--data --logs --online --backup-dir "${BACKUP_DIR}")
{% if not ipa_backup_include_data %}
BACKUP_ARGS=(--logs --online --backup-dir "${BACKUP_DIR}")
{% endif %}

ipa-backup "${BACKUP_ARGS[@]}"

find "${BACKUP_DIR}" -mindepth 1 -maxdepth 1 -type d -name 'ipa-full-*' -print | sort > "${after_list}"
latest_backup="$(comm -13 "${before_list}" "${after_list}" | tail -n 1)"
rm -f "${before_list}" "${after_list}"

if [ -z "${latest_backup}" ]; then
  latest_backup="$(find "${BACKUP_DIR}" -mindepth 1 -maxdepth 1 -type d -name 'ipa-full-*' -printf '%T@ %p\n' | sort -nr | awk 'NR==1 {print $2}')"
fi

[ -n "${latest_backup}" ] && [ -d "${latest_backup}" ] || { echo "Unable to determine latest backup"; exit 1; }

manifest="${MANIFEST_DIR}/$(basename "${latest_backup}").manifest"
{
  echo "backup_name=$(basename "${latest_backup}")"
  echo "backup_path=${latest_backup}"
  echo "host=$(hostname -f 2>/dev/null || hostname)"
  echo "created_at=$(date --iso-8601=seconds)"
  echo "ipa_version=$(rpm -q ipa-server 2>/dev/null || true)"
  echo "files="
  find "${latest_backup}" -type f -printf '%P|%s\n' | sort
} > "${manifest}"
chmod 0640 "${manifest}"

{% if ipa_backup_integrity_check_enabled %}
test -s "${manifest}"
find "${latest_backup}" -type f | grep -q .
du -sh "${latest_backup}"
{% endif %}

{% if ipa_backup_offsite_enabled %}
rsync {{ ipa_backup_offsite_rsync_options }} "${BACKUP_DIR}/" "{{ ipa_backup_offsite_target }}/"
{% else %}
echo "Offsite backup disabled"
{% endif %}

find "${BACKUP_DIR}" -mindepth 1 -maxdepth 1 -type d -name 'ipa-full-*' -mtime "+${RETENTION_DAYS}" -print -exec rm -rf {} \;
find "${LOG_DIR}" -type f -name 'ipa-backup-*.log' -mtime "+${RETENTION_DAYS}" -print -delete
find "${MANIFEST_DIR}" -type f -name '*.manifest' -mtime "+${RETENTION_DAYS}" -print -delete

echo "[$(date --iso-8601=seconds)] IPA backup completed successfully"
