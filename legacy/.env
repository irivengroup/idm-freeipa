COMPOSE_PROJECT_NAME=idmcluster

# Identity domain
DOMAIN=iriven.lab
REALM=IRIVEN.LAB
NETBIOS_NAME=IRIVEN

# Admin credentials - lab only, change before real use
IPA_ADMIN_USER=admin
IPA_ADMIN_PASSWORD=Str0ngAdminPassw0rd!
IPA_DM_PASSWORD=Str0ngDirectoryPassw0rd!
SSH_ROOT_PASSWORD=RockyRootPassw0rd!

# DNS forwarders
DNS_FORWARDER_1=1.1.1.1
DNS_FORWARDER_2=8.8.8.8
DNS_FORWARD_POLICY=only

# Networks
SITE_A_SUBNET=192.168.1.128/26
SITE_A_GATEWAY=192.168.1.129
SITE_B_SUBNET=192.168.1.192/26
SITE_B_GATEWAY=192.168.1.193

# Servers
IDM_PRIMARY_HOST=idmprimarya
IDM_REPLICA_HOST=idmreplicab
IDM_LOADBALANCER_HOST=idmloadbalancer
IDM_PRIMARY_FQDN=idmprimarya.iriven.lab
IDM_REPLICA_FQDN=idmreplicab.iriven.lab
IDM_LOADBALANCER_FQDN=idmloadbalancer.iriven.lab
IDM_PRIMARY_IP=192.168.1.130
IDM_REPLICA_IP=192.168.1.194
IDM_LOADBALANCER_A_IP=192.168.1.131
IDM_LOADBALANCER_B_IP=192.168.1.195

# Auto-enrolled clients
IDMCLIENT1A_HOST=idmclient1a
IDMCLIENT2A_HOST=idmclient2a
IDMCLIENT1B_HOST=idmclient1b
IDMCLIENT2B_HOST=idmclient2b
IDMCLIENT1A_FQDN=idmclient1a.iriven.lab
IDMCLIENT2A_FQDN=idmclient2a.iriven.lab
IDMCLIENT1B_FQDN=idmclient1b.iriven.lab
IDMCLIENT2B_FQDN=idmclient2b.iriven.lab
IDMCLIENT1A_IP=192.168.1.132
IDMCLIENT2A_IP=192.168.1.133
IDMCLIENT1B_IP=192.168.1.196
IDMCLIENT2B_IP=192.168.1.197

# Manual nodes
IDMNODE1A_HOST=idmnode1a
IDMNODE1B_HOST=idmnode1b
IDMNODE1A_FQDN=idmnode1a.iriven.lab
IDMNODE1B_FQDN=idmnode1b.iriven.lab
IDMNODE1A_IP=192.168.1.134
IDMNODE1B_IP=192.168.1.198
